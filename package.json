{
  "name": "concurio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Modern task & contest tracker — Telegram Mini App + Web (2026)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/copy-404.mjs",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"e2e/**/*.{ts,js}\" \"*.{ts,js,json,md}\" \".github/**/*.{yml,yaml}\"",
    "format:check": "prettier --check \"e2e/**/*.{ts,js}\" \"playwright.config.ts\" \"package.json\" \"eslint.config.js\" \"vite.config.ts\" \"vitest.config.ts\" \"CONTRIBUTING.md\" \"ARCHITECTURE.md\"",
    "prepare": "husky",
    "deploy": "npm run build && npx gh-pages -d dist"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,css,json,md}": [
      "prettier --write"
    ],
    "src/**/*.{ts,tsx}": [
      "eslint --fix"
    ],
    "e2e/**/*.{ts,js}": [
      "prettier --write"
    ],
    "*.{json,yml,yaml,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-query": "^5.65.0",
    "@telegram-apps/sdk-react": "3.3.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.0.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.470.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-day-picker": "^9.5.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.5",
    "react-pdf": "^9.2.1",
    "react-router-dom": "^7.1.0",
    "tailwind-merge": "3.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.1.0",
    "vitest": "^3.2.4"
  }
}
